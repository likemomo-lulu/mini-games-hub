/* ==================== 首页样式 ==================== */

/* 页面容器 */
.page-container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  overflow: hidden; /* 防止整体滚动 */
}

/* 头部区域 */
.page-header {
  padding: 40rpx 40rpx 20rpx;
}

.header-top {
  display: flex;
  justify-content: flex-start;
  align-items: center;
  gap: 24rpx;
}

/* 品牌区域 */
.brand-section {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.brand-icon {
  font-size: 56rpx;
  line-height: 1;
}

.brand-text {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.brand-title {
  font-size: 48rpx;
  font-weight: 800;
  line-height: 1.2;
  letter-spacing: 2rpx;
}

.brand-subtitle {
  font-size: 24rpx;
  color: #636E72;
  opacity: 0.8;
}

/* 主题切换按钮 */
.theme-btn {
  display: flex !important;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  width: 160rpx !important; /* 固定宽度，强制生效 */
  height: 64rpx !important; /* 固定高度，强制生效 */
  padding: 0 !important;
  margin: 0 !important;
  border-radius: 32rpx !important;
  font-size: 26rpx;
  font-weight: 600;
  border: none;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
  flex-shrink: 0; /* 防止被压缩 */
  white-space: nowrap; /* 防止文字换行 */
  line-height: 64rpx; /* 垂直居中 */
}

.theme-btn::after {
  border: none !important; /* 移除微信小程序默认边框 */
}

.theme-icon {
  font-size: 28rpx;
}

/* 游戏滚动区域 */
.game-scroll {
  flex: 1;
  height: 0;
  padding: 20rpx 40rpx 40rpx;
  overflow-y: auto; /* 允许垂直滚动 */
  overflow-x: hidden; /* 隐藏横向滚动 */
}

/* 游戏网格 */
.game-grid {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

/* 游戏卡片 */
.game-card {
  position: relative;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 24rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  overflow: hidden;
}

/* 卡片背景层 */
.card-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  opacity: 0.5;
  z-index: 0;
}

/* 卡片内容层 */
.card-content {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  gap: 20rpx;
  flex: 1;
}

/* 游戏 Emoji 图标 */
.game-emoji {
  width: 96rpx;
  height: 96rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
  flex-shrink: 0;
}

/* 游戏信息 */
.game-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.game-title {
  font-size: 32rpx;
  font-weight: 700;
  line-height: 1.2;
}

.game-desc {
  font-size: 24rpx;
  color: #636E72;
  opacity: 0.8;
}

/* 箭头 */
.card-arrow {
  position: relative;
  z-index: 1;
  font-size: 40rpx;
  font-weight: 300;
  opacity: 0.5;
  transition: all 0.3s;
}

/* 卡片悬停效果 */
.game-card-hover {
  transform: translateY(-4rpx) scale(1.02);
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.12);
}

.game-card-hover .card-arrow {
  opacity: 1;
  transform: translateX(8rpx);
}

/* ==================== 动画效果 ==================== */

/* 页面加载动画 */
.game-card {
  animation: slideInUp 0.5s cubic-bezier(0.4, 0, 0.2, 1) backwards;
}

.game-card:nth-child(1) { animation-delay: 0.05s; }
.game-card:nth-child(2) { animation-delay: 0.1s; }
.game-card:nth-child(3) { animation-delay: 0.15s; }
.game-card:nth-child(4) { animation-delay: 0.2s; }
.game-card:nth-child(5) { animation-delay: 0.25s; }
.game-card:nth-child(6) { animation-delay: 0.3s; }
.game-card:nth-child(7) { animation-delay: 0.35s; }
.game-card:nth-child(8) { animation-delay: 0.4s; }

@keyframes slideInUp {
  from {
    transform: translateY(40rpx);
    opacity: 0;
  }
  to {
    transform: translateY(0);
    opacity: 1;
  }
}
