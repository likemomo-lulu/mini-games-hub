<!-- 2048 游戏页 - 精致设计 -->
<view class="container" style="background: {{theme.pageBg}};">
  <!-- 头部信息栏 -->
  <view class="header">
    <view class="header-right">
      <view class="stat-box" style="background: {{theme.headerCardBg}};">
        <text class="stat-label" style="color: {{theme.headerTextLight}};">步数</text>
        <text class="stat-value" style="color: {{theme.headerTextWhite}};">{{steps}}</text>
      </view>
      <view class="stat-box" style="background: {{theme.headerCardBg}};">
        <text class="stat-label" style="color: {{theme.headerTextLight}};">分数</text>
        <text class="stat-value" style="color: {{theme.headerTextWhite}};">{{score}}</text>
      </view>
    </view>
  </view>

  <!-- 控制按钮 -->
  <view class="controls">
    <button
      class="btn"
      bindtap="restart"
      style="background: linear-gradient(135deg, {{theme.accentFrom}} 0%, {{theme.accentTo}} 100%);"
    >重新开始</button>
  </view>

  <!-- 游戏棋盘 -->
  <view class="game-board">
    <canvas
      type="2d"
      id="gameCanvas"
      class="game-canvas"
      style="width: 552rpx; height: 552rpx;"
      bindtouchstart="onTouchStart"
      catchtouchmove="onTouchMove"
      bindtouchend="onTouchEnd"
    ></canvas>

    <!-- 游戏结束覆盖层 -->
    <view class="overlay {{gameOver ? 'show' : ''}}" style="background: {{theme.canvasOverlayBg}};">
      <view class="overlay-content">
        <text class="overlay-title" style="color: {{theme.danger}};">游戏结束</text>
        <text class="overlay-info" style="color: {{theme.headerTextWhite}};">最终得分: {{score}}</text>
        <button class="btn" bindtap="restart" style="background: linear-gradient(135deg, {{theme.accentFrom}} 0%, {{theme.accentTo}} 100%);">再来一局</button>
      </view>
    </view>
  </view>

  <!-- 操作提示 -->
  <view class="tips" style="color: {{theme.tipsText}};">
    💡 滑动移动方块，合并相同数字
  </view>
</view>
