/* 2048 游戏样式 */

.container {
  padding: 40rpx;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* 头部统计 */
.header {
  width: 100%;
  display: flex;
  justify-content: flex-end;
  align-items: center;
  padding: 20rpx 0;
  margin-bottom: 30rpx;
}

.header-right {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 16rpx;
}

.stat-box {
  min-width: 120rpx;
  padding: 16rpx 20rpx;
  border-radius: 20rpx;
  text-align: center;
  backdrop-filter: blur(20rpx);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
}

.stat-label {
  display: block;
  font-size: 22rpx;
  margin-bottom: 4rpx;
}

.stat-value {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  line-height: 1.2;
}

/* 控制按钮区域 */
.controls {
  width: 100%;
  display: flex;
  justify-content: center;
  margin-bottom: 30rpx;
}

/* 游戏棋盘 */
.game-board {
  position: relative;
  width: 552rpx;
  aspect-ratio: 1;
  background: rgba(255, 255, 255, 0.25);
  backdrop-filter: blur(20rpx);
  border-radius: 32rpx;
  padding: 20rpx;
  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.15),
              inset 0 1rpx 1rpx rgba(255, 255, 255, 0.3);
}

.game-canvas {
  width: 552rpx;
  height: 552rpx;
  border-radius: 24rpx;
}

/* 覆盖层 */
.overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  border-radius: 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  z-index: 10;
}

.overlay.show {
  opacity: 1;
  pointer-events: auto;
}

.overlay-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  animation: slideUp 0.5s cubic-bezier(0.4, 0, 0.2, 1);
}

.overlay-title {
  font-size: 72rpx;
  font-weight: 800;
  margin-bottom: 30rpx;
  text-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.2);
}

.overlay-info {
  font-size: 32rpx;
  margin-bottom: 40rpx;
  opacity: 0.9;
}

/* 操作提示 */
.tips {
  margin-top: 30rpx;
  font-size: 26rpx;
  opacity: 0.8;
  text-align: center;
}

/* 动画 */
@keyframes slideUp {
  from {
    transform: translateY(60rpx);
    opacity: 0;
  }
  to {
    transform: translateY(0);
    opacity: 1;
  }
}
