/* 记忆翻牌游戏样式 - 精致设计 */

.container {
  padding: 40rpx;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* 头部统计 */
.header {
  width: 100%;
  display: flex;
  justify-content: flex-end; /* 靠右对齐 */
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 0;
  margin-bottom: 30rpx;
  flex-wrap: wrap;
}

.stat-box {
  min-width: 120rpx;
  padding: 16rpx 20rpx;
  border-radius: 20rpx;
  text-align: center;
  backdrop-filter: blur(20rpx);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
}

.stat-label {
  display: block;
  font-size: 22rpx;
  margin-bottom: 4rpx;
}

.stat-value {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  line-height: 1.2;
}

/* 控制按钮区域 - 使用flex自适应布局 */
.controls {
  width: 100%;
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 30rpx;
}

/* 控制按钮样式 - 自适应平分空间 */
.controls .btn {
  flex: 1;
  min-width: 0; /* 允许按钮缩小到内容宽度 */
  max-width: 280rpx; /* 限制最大宽度，避免按钮过宽 */
}

/* 游戏棋盘 */
.game-board {
  position: relative;
  width: 552rpx;
  aspect-ratio: 1;
  background: rgba(255, 255, 255, 0.25);
  backdrop-filter: blur(20rpx);
  border-radius: 32rpx;
  padding: 20rpx;
  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.15),
              inset 0 1rpx 1rpx rgba(255, 255, 255, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  --card-back-from: #ffeaa7;
  --card-back-to: #fdcb6e;
  --card-front-bg: rgba(255, 255, 255, 0.9);
}

/* 卡片网格 */
.grid {
  display: grid;
  gap: 12rpx;
  width: 100%;
  height: 100%;
}

.grid-2 {
  grid-template-columns: repeat(2, 1fr);
}

.grid-3 {
  grid-template-columns: repeat(3, 1fr);
}

.grid-4 {
  grid-template-columns: repeat(4, 1fr);
}

.grid-5 {
  grid-template-columns: repeat(5, 1fr);
}

.grid-6 {
  grid-template-columns: repeat(6, 1fr);
}

.grid-7 {
  grid-template-columns: repeat(7, 1fr);
}

/* 卡片容器 */
.card-container {
  aspect-ratio: 1;
  perspective: 1000rpx;
  cursor: pointer;
}

/* 根据网格大小调整字体 */
.grid-3 .card-back {
  font-size: 70rpx;
}

.grid-4 .card-back {
  font-size: 55rpx;
}

.grid-5 .card-back {
  font-size: 45rpx;
}

.grid-6 .card-back,
.grid-7 .card-back {
  font-size: 38rpx;
}

/* 卡片翻转容器 */
.card {
  position: relative;
  width: 100%;
  height: 100%;
  transform-style: preserve-3d;
  transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1);
}

.card.flipped {
  transform: rotateY(180deg);
}

.card.matched {
  opacity: 0.6;
  transform: rotateY(180deg) scale(0.95);
}

/* 卡片正反面 */
.card-front,
.card-back {
  position: absolute;
  width: 100%;
  height: 100%;
  backface-visibility: hidden;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.card-front {
  background: var(--card-front-bg);
  backdrop-filter: blur(10rpx);
}

.card-front::after {
  content: '?';
  font-size: 48rpx;
  font-weight: 700;
  color: rgba(0, 0, 0, 0.2);
}

.card-back {
  background: linear-gradient(135deg, var(--card-back-from) 0%, var(--card-back-to) 100%);
  transform: rotateY(180deg);
}

/* 覆盖层 */
.overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  border-radius: 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  z-index: 10;
  padding: 40rpx;
}

.overlay.show {
  opacity: 1;
  pointer-events: auto;
}

.overlay-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  animation: slideUp 0.5s cubic-bezier(0.4, 0, 0.2, 1);
}

.overlay-title {
  font-size: 64rpx;
  font-weight: 800;
  margin-bottom: 20rpx;
  text-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.2);
}

.overlay-text {
  font-size: 28rpx;
  margin-bottom: 30rpx;
}

.overlay-info {
  font-size: 26rpx;
  margin-bottom: 8rpx;
  opacity: 0.9;
}

.overlay-buttons {
  display: flex;
  gap: 16rpx;
  margin-top: 30rpx;
  flex-wrap: wrap;
  justify-content: center;
}

/* 操作提示 */
.tips {
  margin-top: 30rpx;
  font-size: 26rpx;
  opacity: 0.8;
  text-align: center;
}

/* 动画 */
@keyframes slideUp {
  from {
    transform: translateY(60rpx);
    opacity: 0;
  }
  to {
    transform: translateY(0);
    opacity: 1;
  }
}
