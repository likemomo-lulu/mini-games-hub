/* 打水果游戏样式 */

/* 容器 */
.container {
  height: 100vh;
  overflow: hidden;
  padding: 30rpx 20rpx;
  display: flex;
  flex-direction: column;
}

/* 头部信息栏 */
.header {
  width: 100%;
  margin-top: 20rpx;
  margin-bottom: 40rpx;
}

.stats {
  display: flex;
  justify-content: flex-end;
  gap: 15rpx;
  padding: 0 10rpx;
}

.stat-box {
  background: rgba(255, 255, 255, 0.2);
  backdrop-filter: blur(10px);
  padding: 15rpx 25rpx;
  border-radius: 20rpx;
  text-align: center;
  box-shadow: 0 8rpx 25rpx rgba(0, 0, 0, 0.2);
}

.stat-label {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.8);
}

.stat-value {
  font-size: 32rpx;
  font-weight: bold;
  color: white;
}

/* 控制按钮 */
.controls {
  width: 100%;
  display: flex;
  gap: 20rpx;
  margin-top: 40rpx;
  margin-bottom: 30rpx;
}

.btn {
  flex: 1;
  padding: 0;
  border: none;
  border-radius: 25rpx;
  font-size: 28rpx;
  font-weight: bold;
  box-shadow: 0 8rpx 25rpx rgba(0, 0, 0, 0.2);
  height: 80rpx;
  line-height: 80rpx;
  color: white;
}

.btn::after {
  border: none;
}

.btn:active {
  opacity: 0.8;
  transform: scale(0.98);
}

.btn[disabled] {
  opacity: 0.5;
}

/* 游戏区域 */
.game-board {
  position: relative;
  width: 100%;
  max-width: 670rpx;
  backdrop-filter: blur(10px);
  border-radius: 30rpx;
  padding: 24rpx;
  box-shadow: 0 15rpx 50rpx rgba(0, 0, 0, 0.3);
  overflow: hidden;
  margin: 0 auto;
  flex: 1;
  box-sizing: border-box;
}

/* 水果样式 */
.fruit {
  position: absolute;
  width: 50px;
  height: 50px;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  user-select: none;
  transition: transform 0.1s;
}

.fruit:active {
  transform: scale(0.9);
}

/* 粒子特效 */
.particle {
  position: absolute;
  border-radius: 50%;
  pointer-events: none;
}

/* 💥 炸弹粒子 - 星形爆炸效果 */
.particle-bomb {
  border-radius: 0;
  /* 创建爆炸星形：8个角的星形 */
  clip-path: polygon(
    50% 0%,
    61% 35%,
    98% 35%,
    68% 57%,
    79% 91%,
    50% 70%,
    21% 91%,
    32% 57%,
    2% 35%,
    39% 35%
  );
}

/* 覆盖层 */
.overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.85);
  display: flex;
  justify-content: center;
  align-items: center;
  border-radius: 30rpx;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.3s;
  z-index: 10;
}

.overlay.show {
  opacity: 1;
  pointer-events: auto;
}

.overlay-content {
  text-align: center;
  color: white;
}

.overlay-title {
  font-size: 60rpx;
  margin-bottom: 20rpx;
}

.overlay.game-over .overlay-title {
  background: linear-gradient(45deg, #FFD700, #FFA500);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

.overlay-text {
  font-size: 32rpx;
  margin-bottom: 30rpx;
  color: white;
}

.overlay-score {
  font-size: 80rpx;
  font-weight: bold;
  margin-bottom: 40rpx;
  background: linear-gradient(45deg, #f093fb, #f5576c);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

.overlay-buttons {
  display: flex;
  gap: 20rpx;
  justify-content: center;
}

.btn-restart {
  padding: 25rpx 50rpx;
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
  color: white;
  border: none;
  border-radius: 50rpx;
  font-size: 30rpx;
  font-weight: bold;
  box-shadow: 0 8rpx 25rpx rgba(0, 0, 0, 0.3);
}

.btn-restart::after {
  border: none;
}

.btn-restart:active {
  opacity: 0.8;
  transform: scale(0.98);
}

/* 操作提示 */
.tips {
  text-align: center;
  margin-top: 30rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
}
