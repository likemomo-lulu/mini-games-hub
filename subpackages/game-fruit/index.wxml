<!-- 打气球游戏 -->
<view class="container" style="background: {{theme.pageBg}};">
  <!-- 头部信息栏 -->
  <view class="header">
    <view class="stats">
      <view class="stat-box" style="background: {{theme.headerCardBg}};">
        <view class="stat-label" style="color: {{theme.headerTextLight}};">分数</view>
        <view class="stat-value" style="color: {{theme.headerTextWhite}};">{{score}}</view>
      </view>
      <view class="stat-box" style="background: {{theme.headerCardBg}};">
        <view class="stat-label" style="color: {{theme.headerTextLight}};">时间</view>
        <view class="stat-value" style="color: {{theme.headerTextWhite}};">{{timeLeft}}s</view>
      </view>
    </view>
  </view>

  <!-- 控制按钮 -->
  <view class="controls">
    <button
      class="btn"
      bindtap="startGame"
      disabled="{{gameRunning}}"
      style="background: linear-gradient(135deg, {{theme.accentFrom}} 0%, {{theme.accentTo}} 100%);"
    >{{gameRunning ? '游戏中...' : '开始游戏'}}</button>
    <button
      wx:if="{{gameRunning}}"
      class="btn"
      bindtap="pauseGame"
      style="background: linear-gradient(135deg, {{theme.accentFrom}} 0%, {{theme.accentTo}} 100%);"
    >暂停</button>
  </view>

  <!-- 游戏区域 -->
  <view class="game-board" style="background: {{theme.canvasOverlayBg}};">
    <!-- 水果列表 -->
    <view
      wx:for="{{fruits}}"
      wx:key="id"
      class="fruit"
      style="left: {{item.x}}px; top: {{item.y}}px; font-size: {{item.size}}px;"
      bindtap="onFruitTap"
      data-index="{{index}}"
    >{{item.emoji}}</view>

    <!-- 粒子特效列表 -->
    <view
      wx:for="{{particles}}"
      wx:key="id"
      class="particle {{item.type === 'bomb' ? 'particle-bomb' : ''}}"
      style="left: {{item.x}}px; top: {{item.y}}px; width: {{item.size}}px; height: {{item.size}}px; background-color: {{item.color}}; opacity: {{item.life}};"
    ></view>

    <!-- 游戏准备覆盖层 -->
    <view class="overlay game-ready {{gameReady && !gameRunning ? 'show' : ''}}" wx:if="{{!gameRunning && score > 0}}">
      <view class="overlay-content">
        <view class="overlay-title">⏸️ 游戏暂停</view>
        <view class="overlay-text">点击下方按钮继续</view>
      </view>
    </view>

    <!-- 游戏结束覆盖层 -->
    <view class="overlay game-over {{!gameRunning && gameReady ? 'show' : ''}}" wx:if="{{!gameRunning && gameReady}}">
      <view class="overlay-content">
        <view class="overlay-title">🎉 时间到！</view>
        <view class="overlay-text">最终得分</view>
        <view class="overlay-score">{{score}}</view>
        <view class="overlay-buttons">
          <button class="btn-restart" bindtap="startGame">再来一次</button>
        </view>
      </view>
    </view>
  </view>

  <!-- 操作提示 -->
  <view class="tips" style="color: {{theme.tipsText}};">
    💡 点击气球得分 | 金色×5 | 炸弹-30 | 闪电清屏
  </view>
</view>